
<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Welcome to {{ appName }}</title>
  </head>
  <body>
    <h1>Hi {{ name }},</h1>
    <p>
      Welcome to {{ appName }}! Your account for {{ businessName }} has been created.
    </p>
    <p>
      You can log in using this email and the temporary password below.
    </p>
    <p>
      Email: <strong>{{ email }}</strong><br />
      Temporary password: <strong>{{ password }}</strong>
    </p>
    <p>
      Login here: <a href="{{ loginUrl }}">{{ loginUrl }}</a>
    </p>
    <p>
      If you want to update your password right away, use this link:
      <a href="{{ resetUrl }}">{{ resetUrl }}</a>
    </p>
    <p>Regards,<br />{{ appName }} Team</p>
  </body>
</html>
